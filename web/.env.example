# Postgres connection for the live DataSource. When set and the DB has display-ready
# data (a briefing or analyzed stories), the site reads from Postgres; otherwise it
# falls back to the bundled seed content. Copy to .env.local and adjust as needed.
DATABASE_URL=postgresql://worldnews:worldnews@localhost:5433/worldnews

# Engine API for the in-UI "Update news" button (server-side only; token never sent to the browser)
ENGINE_URL=http://localhost:8077
CREW_TOKEN=changeme-match-engine-.env
